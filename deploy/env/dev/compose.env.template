# -----------------------------------------------------------------------------
# File: deploy/env/dev/compose.env.template
# Purpose: 开发环境 Docker Compose 插值配置。
# Scope: 只放编排层变量，例如项目名、镜像、宿主机端口、worker 数。
# Runtime: 容器内部运行时变量请看 deploy/env/dev/services/*.env.template。
# Usage: docker compose --env-file deploy/env/dev/compose.env.template -f docker-compose.dev.yml ...
# -----------------------------------------------------------------------------

# Compose 项目名会影响容器、网络和卷的命名前缀；开发环境固定为 dev，避免与生产资源混淆。
COMPOSE_PROJECT_NAME=vet-agent-dev

# env_file 的根目录。复制本文件为 compose.env 后，也可以把 ENV_DIR 指向一套私有配置目录。
ENV_DIR=./deploy/env/dev

# Python 基础镜像，仅用于构建 Agent app 镜像。
PYTHON_BASE_IMAGE=ghcr.io/astral-sh/uv:python3.12-bookworm

# 共享 PostgreSQL 镜像。必须带 pgvector 扩展，因为 Agent RAG 和 Mem0 语义记忆都会用到向量能力。
PGVECTOR_IMAGE=pgvector/pgvector:pg16

# LiteLLM Proxy 镜像，用于统一代理通义千问 chat / vision / embedding 请求。
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-stable

# Mem0 REST Server 镜像。默认指向已构建好的私有仓库镜像，避免本地源码构建。
MEM0_IMAGE=crpi-efmmpn9a6t9mspwy.cn-hangzhou.personal.cr.aliyuncs.com/vancer-saas/mem0:latest

# Agent API 暴露给宿主机的端口；服务内部始终使用 compose 网络服务名访问。
APP_PORT=8000

# 开发调试用 PostgreSQL 宿主机端口；生产 compose 不暴露该端口。
POSTGRES_PORT=5432

# 开发调试用 LiteLLM 宿主机端口，便于直接调用 /health 或 OpenAI-compatible 接口排查。
LITELLM_PORT=4000

# 开发调试用 Mem0 宿主机端口，便于直接访问 Mem0 REST Server。
MEM0_PORT=8001

# LiteLLM worker 数。开发环境保持较小值，避免本机资源占用过高。
LITELLM_WORKERS=2
