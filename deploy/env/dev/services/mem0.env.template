# -----------------------------------------------------------------------------
# File: deploy/env/dev/services/mem0.env.template
# Purpose: 开发环境 Mem0 REST Server 运行时配置。
# Real Link: 默认启用真实 Mem0 REST Server + pgvector + LiteLLM 模型链路。
# Notes: Mem0 的模型调用使用 OpenAI-compatible 协议转发到 LiteLLM。
# -----------------------------------------------------------------------------

# Mem0 调 LiteLLM 时使用的 API Key；必须等于 litellm.env.template 中的 LITELLM_MASTER_KEY。
OPENAI_API_KEY=sk-dev-litellm-change-me

# OpenAI-compatible base URL，指向 compose 网络内 LiteLLM 服务。
OPENAI_BASE_URL=http://litellm:4000/v1

# 兼容部分 Mem0 / OpenAI SDK 读取 OPENAI_API_BASE 的路径，值与 OPENAI_BASE_URL 保持一致。
OPENAI_API_BASE=http://litellm:4000/v1

# Mem0 默认总结/抽取模型，通过 LiteLLM 映射到通义千问。
MEM0_DEFAULT_LLM_MODEL=qwen-plus

# Mem0 默认 embedding 模型，用于语义记忆向量化。
MEM0_DEFAULT_EMBEDDER_MODEL=text-embedding-v4

# Mem0 REST Server 管理 API key；Agent 的 MEM0_API_KEY 必须使用同一个值。
ADMIN_API_KEY=sk-dev-mem0-change-me

# Mem0 JWT 密钥。开发默认值可启动；共享开发环境请复制为 mem0.env 后替换。
JWT_SECRET=dev-mem0-jwt-secret-change-me-at-least-32-chars

# 是否关闭 Mem0 鉴权。真实链路默认 false，保持与生产行为一致。
AUTH_DISABLED=false

# Mem0 Dashboard 地址，仅作为 Mem0 server 跨域/跳转配置；当前 compose 未启动 dashboard。
DASHBOARD_URL=http://localhost:3000

# 是否发送 Mem0 telemetry。开发和生产默认关闭，避免无关外联。
MEM0_TELEMETRY=false

# Mem0 PostgreSQL 主机，使用 compose 服务名 postgres。
POSTGRES_HOST=postgres

# Mem0 PostgreSQL 端口，容器内固定为 5432。
POSTGRES_PORT=5432

# Mem0 pgvector 语义记忆库。
POSTGRES_DB=mem0_vector

# Mem0 PostgreSQL 登录账号。
POSTGRES_USER=mem0

# Mem0 PostgreSQL 登录密码；必须与 postgres.env.template 中 MEM0_POSTGRES_PASSWORD 一致。
POSTGRES_PASSWORD=mem0

# Mem0 pgvector collection 名称，用于隔离本项目的语义记忆集合。
POSTGRES_COLLECTION_NAME=vet_agent_memories

# Mem0 REST Server 元数据库名。
APP_DB_NAME=mem0_app
