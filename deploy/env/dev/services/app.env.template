# -----------------------------------------------------------------------------
# File: deploy/env/dev/services/app.env.template
# Purpose: 开发环境 Vet Agent API 运行时配置。
# Real Link: 默认启用 PostgreSQL、LiteLLM、Mem0、RAG embedding 等真实链路。
# Notes: 这里是容器内配置，数据库和中间件地址使用 compose 服务名。
# -----------------------------------------------------------------------------

# Agent 业务数据库连接串，指向共享 PostgreSQL 中的 vet_agent 逻辑库。
DATABASE_URL=postgresql://vet_agent:vet_agent@postgres:5432/vet_agent

# LiteLLM OpenAI-compatible base URL；Agent 不直连 DashScope。
LITELLM_BASE_URL=http://litellm:4000/v1

# Agent 调 LiteLLM 使用的 key；必须等于 litellm.env.template 中 LITELLM_MASTER_KEY。
LITELLM_API_KEY=sk-dev-litellm-change-me

# 默认问诊/总结模型。
QWEN_MODEL=qwen-plus

# 默认向量模型。ENABLE_RAG_EMBEDDINGS=true 时，seed/import/RAG 会使用该模型。
QWEN_EMBEDDING_MODEL=text-embedding-v4

# 默认视觉模型，用于 OSS 图片报告解析。
QWEN_VISION_MODEL=qwen-vl-plus

# LiteLLM 请求超时秒数。低频重试/熔断参数使用代码默认值，减少 env 噪音。
LITELLM_TIMEOUT_SECONDS=30

# 是否启用 RAG 向量检索。开发默认 true，确保走真实 embedding 链路。
ENABLE_RAG_EMBEDDINGS=true

# 是否启用 LLM/子 Agent 风格任务拆分。默认 true，支持单轮多任务输入。
ENABLE_LLM_TASK_SPLITTER=true

# 是否启用事实记忆抽取流程。
ENABLE_MEMORY_EXTRACTION=true

# 是否使用 LLM 辅助事实记忆抽取。默认 true，避免只依赖规则抽取。
ENABLE_LLM_MEMORY_EXTRACTION=true

# 是否启用 Mem0 语义记忆增强。默认 true，走真实 Mem0 REST Server。
ENABLE_MEM0=true

# Agent 访问 Mem0 的内部地址。
MEM0_BASE_URL=http://mem0:8000

# Agent 访问 Mem0 的 API key；必须等于 mem0.env.template 中 ADMIN_API_KEY。
MEM0_API_KEY=sk-dev-mem0-change-me

# 报告解析允许的 OSS bucket。开发默认使用 infra dev bucket。
OSS_BUCKET=infra-dev-file-storage

# OSS 对象 key 前缀白名单。空值表示允许该 bucket 下全部对象。
OSS_PREFIX=

# OSS endpoint 白名单。报告解析只接受该 endpoint 下的 OSS 图片地址或对象 key。
OSS_ENDPOINT=oss-cn-hangzhou-internal.aliyuncs.com

# 开发环境默认不强制 API 鉴权，方便手动 curl；共享开发环境可复制 app.env 后填入并开启。
VET_AGENT_API_KEYS=

# 是否强制入口 API 鉴权。生产必须为 true；开发默认 false 只降低本地调试门槛。
REQUIRE_API_AUTH=false

# API 鉴权用户与 vet_context.user_id 是否必须一致。开发默认 false；生产默认 true。
REQUIRE_AUTH_USER_MATCH=false

# 宠物归属校验模式。permissive 会在首次出现时登记 pet_id -> user_id，便于开发联调。
PET_AUTHORIZATION_MODE=permissive

# 会话绑定策略。permissive 会绑定 session_id 与 user/pet，并阻止后续串宠。
SESSION_POLICY_MODE=permissive

# Agent 本地数据目录。PostgreSQL 已启用时仅作为少量兼容数据目录。
VET_AGENT_DATA_DIR=/app/.data

# Seed 数据目录，容器内路径。
VET_AGENT_SEED_DIR=/app/data/seeds

# 开发默认在 seed 阶段写入 embedding，确保 RAG 向量链路可验收。
SEED_WITH_EMBEDDINGS=true
