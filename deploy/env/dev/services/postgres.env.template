# -----------------------------------------------------------------------------
# File: deploy/env/dev/services/postgres.env.template
# Purpose: 开发环境 PostgreSQL 容器运行时配置。
# Topology: 一个 pgvector PostgreSQL 实例承载 Agent、LiteLLM、Mem0 的多个逻辑库。
# Init: docker/postgres/init/10-bootstrap-logical-databases.sh 只在空数据卷首次初始化时读取这些变量。
# -----------------------------------------------------------------------------

# PostgreSQL 官方镜像的默认维护库名；保持 postgres 即可。
POSTGRES_DB=postgres

# PostgreSQL 超级用户。仅用于容器首次初始化和创建各服务的最小权限账号。
POSTGRES_USER=postgres

# PostgreSQL 超级用户密码。开发默认值可直接启动；共享环境请复制为 postgres.env 后修改。
POSTGRES_PASSWORD=postgres

# Agent 业务逻辑库，保存 RAG、对话、记忆、trace、幂等记录等业务数据。
VET_AGENT_POSTGRES_DB=vet_agent

# Agent 业务库登录账号。应用容器只使用该账号连接业务库。
VET_AGENT_POSTGRES_USER=vet_agent

# Agent 业务库登录密码；需要与 app.env.template 中 DATABASE_URL 的密码保持一致。
VET_AGENT_POSTGRES_PASSWORD=vet_agent

# LiteLLM 元数据逻辑库，保存 LiteLLM 自身的 key、日志、预算等元数据。
LITELLM_POSTGRES_DB=litellm

# LiteLLM 元数据库登录账号。
LITELLM_POSTGRES_USER=litellm

# LiteLLM 元数据库登录密码；需要与 litellm.env.template 中 DATABASE_URL 的密码保持一致。
LITELLM_POSTGRES_PASSWORD=litellm

# Mem0 pgvector 语义记忆库，保存向量集合和长期语义记忆数据。
MEM0_POSTGRES_DB=mem0_vector

# Mem0 PostgreSQL 登录账号，同时拥有 mem0_vector 和 mem0_app 两个逻辑库。
MEM0_POSTGRES_USER=mem0

# Mem0 PostgreSQL 登录密码；需要与 mem0.env.template 中 POSTGRES_PASSWORD 保持一致。
MEM0_POSTGRES_PASSWORD=mem0

# Mem0 REST Server 元数据逻辑库，保存用户、API key、请求日志等非向量数据。
MEM0_APP_DB_NAME=mem0_app
