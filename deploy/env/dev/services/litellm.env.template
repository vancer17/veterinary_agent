# -----------------------------------------------------------------------------
# File: deploy/env/dev/services/litellm.env.template
# Purpose: 开发环境 LiteLLM Proxy 运行时配置。
# Real Link: 默认启用真实 LiteLLM -> 通义千问链路；启动前需要填入 DASHSCOPE_API_KEY。
# Notes: Agent 和 Mem0 都只访问 LiteLLM，不直接持有通义千问 Key。
# -----------------------------------------------------------------------------

# LiteLLM 元数据库连接串，指向共享 PostgreSQL 中的 litellm 逻辑库。
DATABASE_URL=postgresql://litellm:litellm@postgres:5432/litellm

# LiteLLM master key。Agent 的 LITELLM_API_KEY 与 Mem0 的 OPENAI_API_KEY 必须使用同一个值。
LITELLM_MASTER_KEY=sk-dev-litellm-change-me

# 通义千问 DashScope API Key。必须填真实值，才能完成 chat / vision / embedding 全链路调用。
DASHSCOPE_API_KEY=replace-with-real-dashscope-api-key
