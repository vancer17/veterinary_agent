# -----------------------------------------------------------------------------
# File: deploy/env/prod/compose.env.template
# Purpose: 正式环境 Docker Compose 插值配置模板。
# Scope: 只放编排层变量，例如项目名、镜像、端口、worker 数和日志滚动策略。
# Runtime: 容器内部运行时变量请看 deploy/env/prod/services/*.env.template。
# Usage: cp deploy/env/prod/compose.env.template deploy/env/prod/compose.env
# -----------------------------------------------------------------------------

# Compose 项目名会影响容器、网络和卷名称；正式环境固定为 prod。
COMPOSE_PROJECT_NAME=vet-agent-prod

# env_file 的根目录。正式部署可指向运维平台下发的配置目录。
ENV_DIR=./deploy/env/prod

# Python 基础镜像，仅用于构建 Agent app 镜像。
PYTHON_BASE_IMAGE=ghcr.io/astral-sh/uv:python3.12-bookworm

# 共享 PostgreSQL 镜像。必须带 pgvector 扩展。
PGVECTOR_IMAGE=pgvector/pgvector:pg16

# LiteLLM Proxy 镜像。
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-stable

# Mem0 REST Server 镜像，默认使用私有仓库构建产物。
MEM0_IMAGE=crpi-efmmpn9a6t9mspwy.cn-hangzhou.personal.cr.aliyuncs.com/vancer-saas/mem0:latest

# Agent app 生产镜像名。make prod-build 会构建该镜像。
VET_AGENT_IMAGE=vet-agent:prod

# Agent API 暴露给宿主机/负载均衡器的端口。
APP_PORT=8000

# Agent app uvicorn worker 数。建议按 CPU、模型调用并发和数据库连接池容量综合设置。
APP_WORKERS=2

# LiteLLM worker 数。过高会增加上游模型与数据库压力。
LITELLM_WORKERS=2

# Docker json-file 单文件日志大小上限。
LOG_MAX_SIZE=20m

# Docker json-file 日志保留文件数。
LOG_MAX_FILE=5
