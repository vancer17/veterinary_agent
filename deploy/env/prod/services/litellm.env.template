# -----------------------------------------------------------------------------
# File: deploy/env/prod/services/litellm.env.template
# Purpose: 正式环境 LiteLLM Proxy 运行时配置模板。
# Real Link: 默认启用真实 LiteLLM -> 通义千问链路；部署前必须填入真实密钥。
# Usage: cp this file to litellm.env and fill secrets before deployment.
# -----------------------------------------------------------------------------

# LiteLLM 元数据库连接串。将 <LITELLM_POSTGRES_PASSWORD> 替换为 postgres.env 中的同名密码。
DATABASE_URL=postgresql://litellm:<LITELLM_POSTGRES_PASSWORD>@postgres:5432/litellm

# LiteLLM master key。Agent 的 LITELLM_API_KEY 与 Mem0 的 OPENAI_API_KEY 必须使用同一个值。
LITELLM_MASTER_KEY=

# 通义千问 DashScope API Key。仅注入 LiteLLM 容器，Agent/Mem0 不直接读取。
DASHSCOPE_API_KEY=
