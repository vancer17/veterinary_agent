# -----------------------------------------------------------------------------
# File: deploy/env/prod/services/app.env.template
# Purpose: 正式环境 Vet Agent API 运行时配置模板。
# Real Link: 默认启用 PostgreSQL、LiteLLM、Mem0、RAG embedding 等真实链路。
# Usage: cp this file to app.env and fill secrets before deployment.
# -----------------------------------------------------------------------------

# Agent 业务数据库连接串。将 <POSTGRES_PASSWORD> 替换为 postgres.env 中 VET_AGENT_POSTGRES_PASSWORD。
DATABASE_URL=postgresql://vet_agent:<POSTGRES_PASSWORD>@postgres:5432/vet_agent

# LiteLLM OpenAI-compatible base URL；Agent 不直连 DashScope。
LITELLM_BASE_URL=http://litellm:4000/v1

# Agent 调 LiteLLM 使用的 key；必须等于 litellm.env 中 LITELLM_MASTER_KEY。
LITELLM_API_KEY=

# 默认问诊/总结模型。
QWEN_MODEL=qwen-plus

# 默认向量模型。ENABLE_RAG_EMBEDDINGS=true 时，seed/import/RAG 会使用该模型。
QWEN_EMBEDDING_MODEL=text-embedding-v4

# 默认视觉模型，用于 OSS 图片报告解析。
QWEN_VISION_MODEL=qwen-vl-plus

# LiteLLM 请求超时秒数。低频重试/熔断参数使用代码默认值，减少 env 噪音。
LITELLM_TIMEOUT_SECONDS=30

# 是否启用 RAG 向量检索。正式环境默认 true，确保走真实 embedding 链路。
ENABLE_RAG_EMBEDDINGS=true

# 是否启用 LLM/子 Agent 风格任务拆分。默认 true，支持单轮多任务输入。
ENABLE_LLM_TASK_SPLITTER=true

# 是否启用事实记忆抽取流程。
ENABLE_MEMORY_EXTRACTION=true

# 是否使用 LLM 辅助事实记忆抽取。默认 true，避免只依赖规则抽取。
ENABLE_LLM_MEMORY_EXTRACTION=true

# 是否启用 Mem0 语义记忆增强。默认 true，走真实 Mem0 REST Server。
ENABLE_MEM0=true

# Agent 访问 Mem0 的内部地址。
MEM0_BASE_URL=http://mem0:8000

# Agent 访问 Mem0 的 API key；必须等于 mem0.env 中 ADMIN_API_KEY。
MEM0_API_KEY=

# 报告解析允许的 OSS bucket。
OSS_BUCKET=infra-prod-file-storage

# OSS 对象 key 前缀白名单。空值表示允许该 bucket 下全部对象。
OSS_PREFIX=

# OSS endpoint 白名单。报告解析只接受该 endpoint 下的 OSS 图片地址或对象 key。
OSS_ENDPOINT=oss-cn-hangzhou-internal.aliyuncs.com

# Agent API 鉴权 key，支持逗号分隔多个 key。正式环境必须填写。
VET_AGENT_API_KEYS=

# 是否强制入口 API 鉴权。正式环境必须为 true。
REQUIRE_API_AUTH=true

# API 鉴权用户与 vet_context.user_id 是否必须一致。正式环境建议 true。
REQUIRE_AUTH_USER_MATCH=true

# 宠物归属校验模式。strict 要求 pet_id 已归属当前 user_id。
PET_AUTHORIZATION_MODE=strict

# 会话绑定策略。strict 禁止同一 session_id 在不同 user/pet 之间复用。
SESSION_POLICY_MODE=strict

# Agent 本地数据目录。PostgreSQL 已启用时仅作为少量兼容数据目录。
VET_AGENT_DATA_DIR=/app/.data

# Seed 数据目录，容器内路径。
VET_AGENT_SEED_DIR=/app/data/seeds

# 正式环境默认在 seed 阶段写入 embedding，确保 RAG 向量链路可验收。
SEED_WITH_EMBEDDINGS=true
