# -----------------------------------------------------------------------------
# File: deploy/env/prod/services/postgres.env.template
# Purpose: 正式环境 PostgreSQL 容器运行时配置模板。
# Topology: 一个 pgvector PostgreSQL 实例承载多个逻辑库，各服务使用独立登录账号。
# Usage: cp this file to postgres.env and fill every password before deployment.
# -----------------------------------------------------------------------------

# PostgreSQL 官方镜像的默认维护库名；保持 postgres 即可。
POSTGRES_DB=postgres

# PostgreSQL 超级用户。只用于首次初始化逻辑库和账号。
POSTGRES_USER=postgres

# PostgreSQL 超级用户密码。正式环境必须使用强随机值。
POSTGRES_PASSWORD=

# Agent 业务逻辑库，保存 RAG、对话、记忆、trace、幂等记录等业务数据。
VET_AGENT_POSTGRES_DB=vet_agent

# Agent 业务库登录账号。应用容器只使用该账号连接业务库。
VET_AGENT_POSTGRES_USER=vet_agent

# Agent 业务库登录密码；必须与 app.env 中 DATABASE_URL 的密码一致。
VET_AGENT_POSTGRES_PASSWORD=

# LiteLLM 元数据逻辑库。
LITELLM_POSTGRES_DB=litellm

# LiteLLM 元数据库登录账号。
LITELLM_POSTGRES_USER=litellm

# LiteLLM 元数据库登录密码；必须与 litellm.env 中 DATABASE_URL 的密码一致。
LITELLM_POSTGRES_PASSWORD=

# Mem0 pgvector 语义记忆库。
MEM0_POSTGRES_DB=mem0_vector

# Mem0 PostgreSQL 登录账号，同时拥有 mem0_vector 和 mem0_app 两个逻辑库。
MEM0_POSTGRES_USER=mem0

# Mem0 PostgreSQL 登录密码；必须与 mem0.env 中 POSTGRES_PASSWORD 一致。
MEM0_POSTGRES_PASSWORD=

# Mem0 REST Server 元数据逻辑库。
MEM0_APP_DB_NAME=mem0_app
