# -----------------------------------------------------------------------------
# 文件: deploy/dev/langgraph-agent-server/.env.example
# 作用: Dev LangGraph Agent Server docker compose 变量模板。
# 用法:
#   1. 在部署目录复制为 .env，并替换所有 change-me / empty-* 占位值。
#   2. .env 只保存在 dev-01 / ci-01 或 CI Secret 中，不提交 Git。
#   3. 当前 graph 入口未就绪时，LANGGRAPH_AGENT_IMAGE 可暂用官方基础镜像
#      做运行底座烟测；正式业务镜像后续由 `langgraph build` 产出。
# -----------------------------------------------------------------------------

# Compose profiles:
# - 默认启动 langgraph-postgres + langgraph-redis 依赖底座。
# - 需要启动 Agent Server 时取消下一行注释，或执行:
#   docker compose --profile agent-server up -d
# COMPOSE_PROFILES=agent-server

ENV=development
LOG_LEVEL=INFO

# Agent Server image and ports.
LANGGRAPH_AGENT_IMAGE=langchain/langgraph-api:3.13
LANGGRAPH_AGENT_SERVER_PORT=8123
LANGGRAPH_POSTGRES_HOST_PORT=15432
LANGGRAPH_REDIS_HOST_PORT=16379

# Agent Server PostgreSQL runtime store.
# 当前为 Dev 本地容器 Postgres；如果 infra 提供托管 PostgreSQL，可直接设置
# LANGGRAPH_DATABASE_URI 并保留下面账号字段作为 fallback。
LANGGRAPH_POSTGRES_DB=langgraph_dev
LANGGRAPH_POSTGRES_USER=langgraph
LANGGRAPH_POSTGRES_PASSWORD=change-me-langgraph-postgres
# LANGGRAPH_DATABASE_URI=postgresql://langgraph:change-me@langgraph-postgres:5432/langgraph_dev?sslmode=disable

# Local compose Redis for Agent Server and local component development.
# Use redis://default:<password>@langgraph-redis:6379/0 inside containers.
# Use redis://default:<password>@127.0.0.1:16379/0 from the host.
# Keep REDIS_PASSWORD and LANGGRAPH_REDIS_PASSWORD equal for local Redis unless
# LANGGRAPH_REDIS_URI points to an external Redis service.
LANGGRAPH_REDIS_USERNAME=default
LANGGRAPH_REDIS_PASSWORD=change-me-langgraph-redis
LANGGRAPH_REDIS_DB=0
REDIS_HOST=langgraph-redis
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=change-me-langgraph-redis
REDIS_DB=0
REDIS_KEY_PREFIX=veterinaryAgent:langgraph:

# Optional Dev cloud Redis override for code running inside dev-01 / VPC.
# Passwords in URI values must be URL-encoded if they contain reserved chars.
# LANGGRAPH_REDIS_URI=redis://petintelli_agent:change-me@r-bp10kgwdml4kqgssoz.redis.rds.aliyuncs.com:6379/2

# Host/container interop URLs.
AGENT_SERVER_BASE_URL_HOST=http://127.0.0.1:8123
AGENT_SERVER_BASE_URL_INTERNAL=http://langgraph-agent-server:8000
API_INGRESS_BASE_URL=http://host.docker.internal:8080
HOST_GATEWAY_BASE_URL=http://host.docker.internal

# LangGraph / LangSmith runtime controls.
LANGGRAPH_CLOUD_LICENSE_KEY=empty-langgraph-license-key
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_TRACING=false

# Conservative Dev sizing for dev-01.
N_JOBS_PER_WORKER=2
BG_JOB_ISOLATED_LOOPS=false
LANGGRAPH_POSTGRES_POOL_MAX_SIZE=10
REDIS_MAX_CONNECTIONS=200
BG_JOB_MAX_RETRIES=3
BG_JOB_SHUTDOWN_GRACE_PERIOD_SECS=180
RESUMABLE_STREAM_TTL_SECONDS=300
MOUNT_PREFIX=

# Project business MySQL RDS. This is not the Agent Server checkpoint database.
DB_HOST=rm-bp1wjjf373l7t331v.mysql.rds.aliyuncs.com
DB_PORT=3306
DB_NAME=app_dev
DB_USER=app_dev
DB_PASSWORD=change-me-app-dev-password

# Dev OSS. ECS should use RAM role; do not place AK/SK here.
OSS_BUCKET=infra-dev-file-storage
OSS_PREFIX=
OSS_ENDPOINT=oss-cn-hangzhou-internal.aliyuncs.com

# Log rotation.
LANGGRAPH_LOG_MAX_SIZE=50m
LANGGRAPH_LOG_MAX_FILE=5
POSTGRES_LOG_MAX_SIZE=20m
POSTGRES_LOG_MAX_FILE=3
