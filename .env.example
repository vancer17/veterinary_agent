# =============================================================================
# .env.example — 本地基础集成测试与真实运行链路示例环境变量
# =============================================================================
#
# 【用途】
#   为 compose.dev.yml 和本地真实运行链路提供可复制的默认环境变量。
#
# 【边界】
#   仅保留当前 compose / 应用链路会实际读取的变量；不保留已废弃的资产路径占位。
#
# =============================================================================

# 本地基础集成测试与真实运行链路默认值
# 如需修改用户名、密码或数据库名，请同步更新 DATABASE_URL。
POSTGRES_DB=veterinary_agent_dev
POSTGRES_USER=veterinary_agent
POSTGRES_PASSWORD=veterinary_agent
DATABASE_URL=postgresql+psycopg://veterinary_agent:veterinary_agent@postgres:5432/veterinary_agent_dev
LANGGRAPH_POSTGRES_SETUP_ON_STARTUP=true
LANGGRAPH_STRICT_MSGPACK=true
LOG_LEVEL=INFO
