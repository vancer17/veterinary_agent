# LLM（WP4 文案阶段再填）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# 制品路径（相对项目根）
TRIAGE_CORE_PATH=assets/triage-core/triage-core.v1.json
KB_TPL_DIR=assets/kb-tpl/config
# 开发
LOG_LEVEL=INFO

# HTTP 入口（L0）
# 为空表示关闭服务间密钥校验；非空时 /v1/* 请求必须携带 X-Service-Key。
AGENT_SERVICE_KEY=
# 服务间密钥请求头名称。
HTTP_SERVICE_KEY_HEADER=X-Service-Key
# 默认受服务间密钥保护的路径前缀。
HTTP_PROTECTED_PATH_PREFIX=/v1/
# trace_id 请求头名称；默认与 BFF 契约一致。
HTTP_TRACE_ID_HEADER=X-Trace-Id
# trace_id 写入 ASGI scope["state"] 的键名。
HTTP_TRACE_ID_STATE_KEY=trace_id
# 是否在响应头回写 trace_id。
HTTP_TRACE_ID_RESPONSE_HEADER_ENABLED=true
# 访问日志器名称。
HTTP_ACCESS_LOGGER_NAME=veterinary_agent.http.access
# 访问日志级别；支持 DEBUG/INFO/WARNING/ERROR 或数字级别。
HTTP_ACCESS_LOG_LEVEL=INFO
# 是否在访问日志中记录客户端主机地址。
HTTP_ACCESS_LOG_INCLUDE_CLIENT_HOST=true
# 是否在访问日志中记录 User-Agent；默认关闭以减少噪声。
HTTP_ACCESS_LOG_INCLUDE_USER_AGENT=false
# /ready 是否也需要 X-Service-Key；默认关闭，便于健康探针调用。
HTTP_READY_REQUIRES_SERVICE_KEY=false
